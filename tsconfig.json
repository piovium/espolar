{
  "compilerOptions": {
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    
    "types": [],
    
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "allowImportingTsExtensions": true,

    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,

    "skipLibCheck": true,

    "strict": true,
  },
  "include": ["src", "test"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
