{
  "compilerOptions": {
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "allowImportingTsExtensions": true,

    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,

    "skipLibCheck": true,

    "types": [
      "node",
      "vitest/globals"
    ],

    "strict": true,
  },
  "include": [
    "test",
    "tsdown.config.ts"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
